# -----------------------------------------------------------------------------
# VCS
# -----------------------------------------------------------------------------
.git
.gitignore

# -----------------------------------------------------------------------------
# Editor / OS junk
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*.tmp
*.bak
*.log

# -----------------------------------------------------------------------------
# Rust / Cargo (not needed for sqlx-cli runtime image)
# -----------------------------------------------------------------------------
target/
**/target/
Cargo.lock
Cargo.toml
.crates.toml
.crates2.json

# -----------------------------------------------------------------------------
# Node / frontend (if present in repo)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log
yarn.lock
pnpm-lock.yaml

# -----------------------------------------------------------------------------
# Local env / secrets (explicitly COPY what you need)
# -----------------------------------------------------------------------------
.env.local
.env.dev
.env.stage
.env.prod

# -----------------------------------------------------------------------------
# Docker artifacts
# -----------------------------------------------------------------------------
Dockerfile~
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Tests / artifacts not needed in image unless explicitly copied
# (pg_tests are copied explicitly in Dockerfile)
# -----------------------------------------------------------------------------
**/*.out
**/*.tap

# -----------------------------------------------------------------------------
# SQLx / runtime junk
# -----------------------------------------------------------------------------
.sqlx/
.sqlx-data.json

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
README.md
docs/
